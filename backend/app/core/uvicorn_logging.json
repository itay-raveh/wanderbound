{
  "version": 1,
  "disable_existing_loggers": false,
  "handlers": {
    "null": {
      "class": "logging.NullHandler"
    }
  },
  "loggers": {
    "uvicorn": {
      "handlers": ["null"],
      "propagate": false
    },
    "uvicorn.error": {
      "handlers": ["null"],
      "propagate": false
    },
    "uvicorn.access": {
      "handlers": ["null"],
      "propagate": false
    }
  }
}
