<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description"
              content="Photo album generated from Polarsteps trip data" />
        <title>Polarsteps Album</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Hebrew:wght@400;500;600&family=Inter:wght@400;500;600;700&display=swap"
              rel="stylesheet" />
        <link rel="stylesheet" href="assets/css/variables.css" />
        <link rel="stylesheet" href="assets/css/reset.css" />
        <link rel="stylesheet" href="assets/css/layout.css" />
        <link rel="stylesheet" href="assets/css/components.css" />
        <link rel="stylesheet" href="assets/css/typography.css" />
        <link rel="stylesheet" href="assets/css/typography.css" />
        <link rel="stylesheet" href="assets/css/photos.css" />
        <link rel="stylesheet" href="assets/css/summary.css" />
        <link rel="stylesheet" href="assets/css/title.css" />
        <link rel="stylesheet"
              href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
              integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
              crossorigin="" />
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
                integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
                crossorigin=""></script>
    </head>
    <body {% if light_mode %}class="light-mode"{% endif %}>
        {% include "title_page.html.jinja" %}
        {% if summary %}
            {% include "trip_summary.html.jinja" %}
        {% endif %}
        {% if trip.path_points %}
            {% include "map_page.html.jinja" %}
        {% endif %}
        {% for step in steps %}
            {% include "step_page.html.jinja" %}
        {% endfor %}
        {% if editor_mode %}
            <script src="editor.js"></script>
            <link rel="stylesheet" href="editor.css" />
        {% endif %}
    </body>
</html>
