<!DOCTYPE html>
<html lang="en">
    <head>
        <title>{{ trip.title }}</title>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content="{{ trip.summary }}" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Hebrew:wght@400;500;600&family=Inter:wght@400;500;600;700&display=swap"
              rel="stylesheet" />
        <link rel="stylesheet"
              href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
              integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
              crossorigin="" />
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
                integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
                crossorigin=""></script>
        <style>
        /* Base */
        {% include 'css/base/reset.css' %}
        {% include 'css/base/variables.css' %}
        {% include 'css/base/typography.css' %}
        {% include 'css/base/layout.css' %}

        /* Modules */
        {% include 'css/modules/grids.css' %}
        {% include 'css/modules/maps.css' %}
        {% include 'css/modules/video.css' %}

        /* Pages */
        {% include 'css/pages/title.css' %}
        {% include 'css/pages/overview.css' %}
        {% include 'css/pages/step.css' %}

        /* Editor */
        {% include 'editor/editor.css' %}
        </style>
        <script>{% include 'editor/editor.js' %}</script>
    </head>
    <body {% if light_mode %}class="light-mode"{% endif %}>
        {% include "templates/title_page.html.jinja" %}
        {% include "templates/trip_overview.html.jinja" %}
        {% include "templates/map_page.html.jinja" %}
        {% for step in steps %}
            {% include "templates/step_page.html.jinja" %}
        {% endfor %}
        <button id="save-btn" class="save-btn" disabled>SAVE</button>
    </body>
</html>
