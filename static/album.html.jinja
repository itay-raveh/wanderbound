<!DOCTYPE html>
<html lang="en">
    <head>
        <title>{{ trip.title }}</title>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content="{{ trip.subtitle }}" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Hebrew:wght@400;500;600&family=Inter:wght@400;500;600;700&display=swap"
              rel="stylesheet" />
        <link rel="stylesheet"
              href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
              integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
              crossorigin="" />
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
                integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
                crossorigin=""></script>
        <style>
        /* Base */
        {% include 'css/base/reset.css' %}
        {% include 'css/base/variables.css' %}
        {% include 'css/base/typography.css' %}
        {% include 'css/base/layout.css' %}

        /* Modules */
        {% include 'css/modules/grids.css' %}
        {% include 'css/modules/maps.css' %}
        {% include 'css/modules/video.css' %}

        /* Pages */
        {% include 'css/pages/title.css' %}
        {% include 'css/pages/overview.css' %}
        {% include 'css/pages/step.css' %}

        /* Editor */
        {% include 'editor/editor.css' %}
        </style>
        <script>{% include 'editor/editor.js' %}</script>
    </head>
    <body {% if light_mode %}class="light-mode"{% endif %}>
        {% include "templates/title_page.html.jinja" %}
        {% include "templates/trip_overview.html.jinja" %}
        {% set map_ctx = main_map %}
        {% include "templates/map_page.html.jinja" %}
        {% for step in steps %}
            {% if loop.index0 in submaps %}
                {% set map_ctx = submaps[loop.index0] %}
                {% include "templates/map_page.html.jinja" %}
            {% endif %}
            {% include "templates/step_page.html.jinja" %}
        {% endfor %}
        <div class="fab-container">
            <button id="print-btn" class="fab-btn print-btn" onclick="window.print()" title="Print Album">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="6 9 6 2 18 2 18 9"></polyline>
                    <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path>
                    <rect x="6" y="14" width="12" height="8"></rect>
                </svg>
            </button>
            <button id="save-btn" class="fab-btn save-btn" disabled title="Save Changes">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path>
                    <polyline points="17 21 17 13 7 13 7 21"></polyline>
                    <polyline points="7 3 7 8 15 8"></polyline>
                </svg>
            </button>
        </div>
    </body>
</html>
