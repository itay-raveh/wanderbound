<div class="step-page page-container {% if step.is_long_description %}with-long-desc{% endif %}"
     data-step-id="{{ step.id }}"
     data-step-name="{{ step.name }} ({{ step.country }})"
     data-step-cover="{{ step.cover_photo }}">
    <div class="step-data">
        <div class="location-section">
            <div class="map-coords-container">
                <div class="map-icon">
                    <div class="map-svg-container">
                        {{ step.country_map_svg | safe }}
                        <div class="map-location-dot"
                             style="left: {{ step.map_dot_x }}%;
                                    top: {{ step.map_dot_y }}%;
                                    background: {{ step.accent_color }}"></div>
                    </div>
                </div>
                <div class="coordinates">
                    {{ step.coords_lat }}
                    <br />
                    {{ step.coords_lon }}
                </div>
            </div>
            <div class="country">
                <img src="{{ step.country_flag_data_uri }}"
                     alt="{{ step.country }} flag"
                     class="country-flag" />
                {{ step.country | upper }}
            </div>
            <div class="step-name">{{ step.name }}</div>
        </div>
        {%- if not step.is_long_description -%}
            <div class="step-description {{ step.desc_dir }}">{{- step.description -}}</div>
        {%- endif -%}
        <div class="metadata-section">
            <div class="metadata">
                <div class="metadata-item">
                    <div class="metadata-label">{{ step.date_month }}</div>
                    <div class="metadata-value">{{ step.date_day }}</div>
                </div>
                <div class="metadata-item">
                    <div class="metadata-label">
                        {% if step.night_weather_icon_url %}
                            <img src="{{ step.night_weather_icon_url }}"
                                 alt="Night weather"
                                 class="weather-icon" />
                        {% endif %}
                        {{ step.temp_night_str }}
                    </div>
                    <div class="metadata-value">
                        {% if step.day_weather_icon_url %}
                            <img src="{{ step.day_weather_icon_url }}"
                                 alt="Day weather"
                                 class="weather-icon" />
                        {% endif %}
                        {{ step.temp_str }}
                    </div>
                </div>
                <div class="metadata-item">
                    <div class="metadata-label">m.a.s.l</div>
                    <div class="metadata-value">{{ step.altitude_str }}</div>
                </div>
            </div>
            <div class="progress-container">
                <div class="progress-bar">
                    <div class="progress-fill"
                         style="width: {{ step.progress_percent }}%;
                                background: {{ step.accent_color }}"></div>
                </div>
                <div class="day-counter-arrow"
                     style="border-bottom-color: {{ step.accent_color }};
                            left: {{ step.day_counter_arrow_position }}%;
                            transform: translateX(-55%)"></div>
                <div class="day-counter-wrapper"
                     style="left: {{ step.day_counter_box_position }}%;
                            transform: translateX(-55%)">
                    <div class="day-counter" style="background: {{ step.accent_color }};">DAY {{ step.day_num }}</div>
                </div>
            </div>
        </div>
    </div>
    <div class="step-content">
        {% if step.is_long_description %}
            <div class="long-description {{ step.desc_dir }}">{{- step.description -}}</div>
        {% elif step.cover_photo %}
            <img src="{{ step.cover_photo }}"
                 alt="{{ step.name }}"
                 class="main-image"
                 {% if step.cover_photo %}data-photo-path="{{ step.cover_photo }}"{% endif %} />
        {% else %}
            <div class="no-image-message">No image available</div>
        {% endif %}
    </div>
    {# Hidden photos container (preserved for editor state) #}
    <div class="hidden-photos-container">
        {% for photo in step.hidden_photos %}
            <div class="photo-item" data-photo-path="{{ photo.path }}">
                <img src="{{ photo.path }}" alt="Hidden {{ photo }}" draggable="true" />
            </div>
        {% endfor %}
    </div>
    <div class="step-index">{{ step.index }}</div>
</div>
{# Photo pages for this step #}
{% for photo_page in step.photo_pages %}
    <div class="step-page photo-page page-container"
         data-step-id="{{ step.id }}">
        <div class="photo-page-container {{ photo_page.layout_class or '' }}"
             {% if photo_page.grid_style %}style="{{ photo_page.grid_style }}"{% endif %}>
            {% for photo in photo_page.photos %}
                <div class="photo-item"
                     data-photo-path="{{ photo.path }}"
                     data-photo="{{ photo.model_dump_json() }}">
                    {% if photo.is_video %}
                        <div class="video-wrapper"
                             style="aspect-ratio: {{ photo.width }} / {{ photo.height }}">
                            <img src="{{ photo.path }}"
                                 alt="Video Frame"
                                 class="video-poster photo-image"
                                 draggable="true" />
                            <div class="play-overlay" onclick="toggleVideo(this)"></div>
                            <video src="{{ photo.video_src }}"
                                   class="video-player photo-image"
                                   controls
                                   preload="metadata">
                            </video>
                            <button class="set-frame-btn"
                                    onclick="videoSetFrame(this, '{{ step.id }}', '{{ photo.video_src }}')">
                                Set Frame
                            </button>
                        </div>
                    {% else %}
                        <img src="{{ photo.path }}"
                             alt="{{ photo.path }}"
                             class="photo-image"
                             draggable="true" />
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    </div>
{% endfor %}
<div class="add-page-container">
    <button class="add-page-btn"
            title="Add Photo Page"
            onclick="addPhotoPage('{{ step.id }}', this)">+</button>
</div>
