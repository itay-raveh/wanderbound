<div class="title-page-container">
    {% if trip.cover_photo %}
        <img src="{{ trip.cover_photo }}"
             class="title-page-cover"
             alt="Trip Cover Photo">
    {% endif %}
    <div class="title-page-overlay">
        <div class="title-page-content">
            <div class="title-page-dates">{{ trip.date_range }}</div>
            <h1 class="title-page-title" dir="{{ trip.title_dir }}">{{ trip.title }}</h1>
            {% if trip.summary %}
                <div class="title-page-summary" dir="{{ trip.subtitle_dir }}">{{ trip.subtitle }}</div>
            {% endif %}
        </div>
    </div>
</div>
