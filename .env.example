# ~~~~~~~~~~~~~~~~~~~ Main Settings ~~~~~~~~~~~~~~~~~~~

# SECRET_KEY=    # Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# VITE_GOOGLE_CLIENT_ID=     # From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# VITE_MAPBOX_TOKEN=
# VITE_CONTACT_EMAIL=
# VITE_GITHUB_URL=
# VITE_AUTHOR_NAME=
# VITE_AUTHOR_URL=

# ~~~~~~~~~~~~~~~~~~~ Other Settings ~~~~~~~~~~~~~~~~~~

PROJECT_NAME="Polarsteps Album Generator"

DOMAIN=localhost
FRONTEND_URL=http://localhost:5173

# Deployment
ENVIRONMENT=local

# Frontend
VITE_MAX_UPLOAD_GB=4
VITE_BACKEND_URL=http://localhost:8000

# Backend
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173"

# Postgres
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
