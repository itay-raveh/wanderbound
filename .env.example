# --- Deployment -------------------------------------------------

# Local Compose builds the dev image. Set a published MAJOR.MINOR.PATCH tag
# when running compose.yml without the development override.
WANDERBOUND_VERSION=dev
DOMAIN=localhost
ENVIRONMENT=local
PUBLIC_URL=http://localhost:8000

# --- Application secrets ---------------------------------------

SECRET_KEY=                                               # python -c "import secrets; print(secrets.token_urlsafe(32))"
# SECRET_KEY_PREVIOUS=                                    # Previous key during rotation

# --- Authentication --------------------------------------------

# Production requires at least one provider.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=

# --- Browser-visible installation values -----------------------

MAPBOX_TOKEN=                                             # Free tier at https://mapbox.com
# CONTACT_EMAIL=
# GITHUB_URL=
# AUTHOR_NAME=
# AUTHOR_URL=

# --- Monitoring -------------------------------------------------

# SENTRY_DSN=                                             # Python SDK project
# PUBLIC_SENTRY_DSN=                                      # Browser SDK project
# SENTRY_TRACES_SAMPLE_RATE=

# The optional `sentry` Compose profile uses these only while uploading maps.
# SENTRY_URL=
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# --- PostgreSQL topology ---------------------------------------

POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# --- S3-compatible uploads -------------------------------------

GARAGE_RPC_SECRET=                                        # openssl rand -hex 32
UPLOAD_S3_BUCKET=wanderbound-uploads
UPLOAD_S3_REGION=garage
UPLOAD_S3_INTERNAL_ENDPOINT_URL=http://object-storage:3900
UPLOAD_S3_PUBLIC_ENDPOINT_URL=http://localhost:3900
UPLOAD_S3_ADDRESSING_STYLE=path
UPLOAD_S3_ACCESS_KEY_ID=                                  # printf 'GK%s\n' "$(openssl rand -hex 16)"
UPLOAD_S3_SECRET_ACCESS_KEY=                              # openssl rand -hex 32

# --- Optional overrides ----------------------------------------

# CORS_ORIGINS=                                           # Extra comma-separated origins
# DATA_FOLDER=
# MAX_STORAGE_BYTES=                                      # 0 lets the app detect available capacity
# MAX_UPLOAD_SIZE_BYTES=
# UPLOAD_S3_PRESIGN_TTL_SECONDS=
# UPLOAD_SESSION_TTL_SECONDS=
# DBOS_SYSTEM_DATABASE_URI=
# DBOS_EXECUTOR_ID=
# DBOS_ADMIN_PORT=
# DBOS_RUN_ADMIN_SERVER=
# DBOS_HEARTBEAT_TTL_SECONDS=
# DBOS_RECOVERY_INTERVAL_SECONDS=
