# --- Required -----------------------------------------

SECRET_KEY=               # python -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_PASSWORD=        # Any value (local dev: "postgres" is fine)

# --- Required in production ---------------------------
# These have dev-friendly defaults but MUST be set when ENVIRONMENT=production.
# The app will refuse to start in production without them.
# At least one auth provider (Google or Microsoft) must be configured.

VITE_GOOGLE_CLIENT_ID=    # Google Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0 Client ID
VITE_MICROSOFT_CLIENT_ID= # Azure Portal -> App registrations -> Application (client) ID
GOOGLE_CLIENT_SECRET=         # Google Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0 Client Secret
VITE_MAPBOX_TOKEN=        # Free tier at https://mapbox.com

# --- Optional - Key Rotation -------------------------
# Old SECRET_KEY, kept during a rotation so existing encrypted tokens
# stay readable. Users whose tokens were not re-encrypted before you
# remove this are prompted to reconnect Google Photos - not a data-loss
# path, just a one-time UX bump.

# SECRET_KEY_PREVIOUS=

# --- Optional - App ----------------------------------

# VITE_CONTACT_EMAIL=
# VITE_GITHUB_URL=
# VITE_AUTHOR_NAME=
# VITE_AUTHOR_URL=

# --- Optional - Monitoring ---------------------------
# Create two Sentry projects (Python + Vue) at https://sentry.io

# SENTRY_DSN=               # Backend (Python/FastAPI)
# VITE_SENTRY_DSN=          # Frontend (Vue/browser) - separate Sentry project
# SENTRY_AUTH_TOKEN=        # Org auth token for source map uploads
# SENTRY_ORG=               # Sentry org slug (for source map uploads)
# SENTRY_FRONTEND_PROJECT=  # Sentry project slug (for source map uploads)
# SENTRY_RELEASE=           # Backend release tag, set it to $(git rev-parse HEAD) at deploy

# --- Defaults -----------------------------------------
# These ship with working local-dev values.
# For production: set DOMAIN, ENVIRONMENT=production,
# and VITE_FRONTEND_URL=https://<domain>.

ENVIRONMENT=local                  # local | production
DOMAIN=localhost                   # Used in Traefik labels and to construct the backend URL
VITE_FRONTEND_URL=http://localhost:5173
BACKEND_CORS_ORIGINS=              # Comma-separated extra origins (VITE_FRONTEND_URL is always allowed)
VITE_MAX_UPLOAD_GB=4
MAX_STORAGE_BYTES=10737418240       # 10 GB. 0 = auto-detect (90% of filesystem capacity).

# --- Defaults - Postgres -----------------------------
# Only change if you have a custom Postgres setup.

POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres

# --- Defaults - Backups -------------------------------
# DB backups: tiered retention (daily/weekly/monthly snapshots).
# Data backups: flat retention (delete after N days).

# BACKUP_DB_SCHEDULE=0 3 * * *       # cron expression for DB dump
# BACKUP_KEEP_DAYS=7                 # daily snapshots to keep
# BACKUP_KEEP_WEEKS=4                # weekly snapshots to keep
# BACKUP_KEEP_MONTHS=6               # monthly snapshots to keep
# BACKUP_DATA_SCHEDULE=0 4 * * *     # cron expression for data volume archive
# BACKUP_RETENTION_DAYS=7            # days to keep data archives
