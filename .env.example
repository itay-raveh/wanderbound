# Generate secret values with: openssl rand -hex 32
# Generate the Garage access key with: printf 'GK%s\n' "$(openssl rand -hex 16)"

# --- Required ---------------------------------------------------

SECRET_KEY=
POSTGRES_PASSWORD=
GARAGE_RPC_SECRET=
UPLOAD_S3_ACCESS_KEY_ID=
UPLOAD_S3_SECRET_ACCESS_KEY=
# Free tier at https://mapbox.com
VITE_MAPBOX_TOKEN=
# Exact hostname used by the Traefik frontend router
DOMAIN=localhost
VITE_FRONTEND_URL=http://localhost:5173

# Production requires at least one auth provider. Google also requires its
# matching client secret.

# Google OAuth client ID and matching client secret
# VITE_GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Microsoft application client ID
# VITE_MICROSOFT_CLIENT_ID=

# --- Compose-local infrastructure -------------------------------

POSTGRES_DB=app
POSTGRES_USER=postgres
SQLALCHEMY_DATABASE_URI=postgresql+psycopg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}

UPLOAD_S3_BUCKET=wanderbound-uploads
UPLOAD_S3_REGION=garage
UPLOAD_S3_INTERNAL_ENDPOINT_URL=http://localhost:3900
UPLOAD_S3_PUBLIC_ENDPOINT_URL=${UPLOAD_S3_INTERNAL_ENDPOINT_URL}
UPLOAD_S3_BROWSER_ORIGIN=${UPLOAD_S3_PUBLIC_ENDPOINT_URL}
UPLOAD_S3_ADDRESSING_STYLE=path

# Garage is the local Compose object store. Production deployments must set the
# exact private and public S3 endpoints supplied by their storage provider.

# --- Optional overrides -----------------------------------------

# SECRET_KEY_PREVIOUS=
# ENVIRONMENT=
# FRONTEND_URL=
# BACKEND_CORS_ORIGINS=
# DATA_FOLDER=
# MAX_STORAGE_BYTES=
# LOG_LEVEL=
# APP_VERSION=
# UPLOAD_S3_PRESIGN_TTL_SECONDS=
# UPLOAD_SESSION_TTL_SECONDS=
# HEAVY_OPERATION_MEMORY_RESERVE_MB=
# HEAVY_OPERATION_MEMORY_MB=

# DBOS_SYSTEM_DATABASE_URI=
# DBOS_EXECUTOR_ID=
# DBOS_ADMIN_PORT=
# DBOS_RUN_ADMIN_SERVER=
# DBOS_HEARTBEAT_TTL_SECONDS=
# DBOS_RECOVERY_INTERVAL_SECONDS=

