# ──────────────────────────────────────────────────────
#  Wanderbound — Environment Configuration
#  Copy this file:  cp .env.example .env
#  Then fill in the REQUIRED values below.
# ──────────────────────────────────────────────────────

# ─── Required ─────────────────────────────────────────
# These have no defaults — the app won't start without them.

SECRET_KEY=              # python -c "import secrets; print(secrets.token_urlsafe(32))"
VITE_GOOGLE_CLIENT_ID=   # Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
VITE_MAPBOX_TOKEN=       # Free tier at https://mapbox.com
POSTGRES_PASSWORD=       # Any value (local dev: "postgres" is fine)

# ─── Optional — App ──────────────────────────────────
# Uncomment and set as needed.

# VITE_CONTACT_EMAIL=
# VITE_GITHUB_URL=
# VITE_AUTHOR_NAME=
# VITE_AUTHOR_URL=

# ─── Optional — Monitoring ───────────────────────────
# Create two Sentry projects (Python + Vue) at https://sentry.io

# SENTRY_DSN=            # Backend (Python/FastAPI)
# VITE_SENTRY_DSN=       # Frontend (Vue/browser) — separate Sentry project
# SENTRY_AUTH_TOKEN=     # Org auth token for source map uploads (Settings → Auth Tokens)
# SENTRY_ORG=            # Organization slug from sentry.io
# SENTRY_PROJECT=        # Frontend project slug from sentry.io

# ─── Defaults — Override for Production ──────────────
# These ship with working local-dev values.
# For production: set DOMAIN, ENVIRONMENT=production,
# FRONTEND_URL=https://<domain>, and add https://<domain>
# to BACKEND_CORS_ORIGINS.

ENVIRONMENT=local                  # local | staging | production
DOMAIN=localhost
FRONTEND_URL=http://localhost:5173
VITE_BACKEND_URL=http://localhost:8000
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173"
VITE_MAX_UPLOAD_GB=4

# ─── Defaults — Postgres ─────────────────────────────
# Only change if you have a custom Postgres setup.

POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
