<div class="photo-item" data-photo="{{ photo.model_dump_json() }}">
    {% if photo.is_video %}
        <div class="video-wrapper" style="aspect-ratio: {{ photo.aspect_ratio }}">
            <img src="{{ photo.path }}"
                 alt="{{ photo.path }} Frame"
                 class="video-poster photo-image"
                 draggable="true"
                 loading="lazy"
                 decoding="async" />
            <div class="play-overlay" onclick="toggleVideo(this)"></div>
            <video src="{{ photo.src }}"
                   class="video-player photo-image"
                   controls
                   preload="none">
            </video>
            <button class="set-frame-btn"
                    onclick="videoSetFrame(this, '{{ step.id }}', '{{ photo.src }}')">Set Frame</button>
        </div>
    {% else %}
        <img src="{{ photo.path }}"
             alt="{{ photo.path }}"
             class="photo-image"
             draggable="true"
             loading="lazy"
             decoding="async" />
    {% endif %}
</div>
