<div class="step-wrapper"
     data-id="{{ step.id }}"
     data-name="{{ step.name }}"
     data-cover="{{ step.cover_photo.model_dump_json() }}">
    <div class="step-pages">
        <div class="step-page page-container {% if step.is_long_description %}with-long-desc{% endif %}">
            <div class="step-data">
                <div>
                    <div class="map-coords-container">
                        <div class="map-icon">
                            <div class="map-svg-container">
                                {{ step.country_map_svg | safe }}
                                <div class="map-location-dot"
                                     style="left: {{ step.map_dot_x }}%;
                                            top: {{ step.map_dot_y }}%;
                                            background: {{ step.accent_color }}"></div>
                            </div>
                        </div>
                        <div class="coordinates">
                            {{ step.lat_str }}
                            <br />
                            {{ step.lon_str }}
                        </div>
                    </div>
                    <div class="country">
                        <img src="{{ step.country_flag_data_uri }}"
                             alt="{{ step.country }} flag"
                             class="country-flag" />
                        {{ step.country | upper }}
                    </div>
                    <div class="step-name">{{ step.name }}</div>
                </div>
                {%- if not step.is_long_description -%}
                    <div class="step-description short"
                         dir="{{ step.description | text_dir }}">{{- step.description -}}</div>
                {%- endif -%}
                <div class="metadata-section">
                    <div class="metadata">
                        <div class="metadata-item">
                            <div class="metadata-label">{{ step.date_month }}</div>
                            <div class="metadata-value">{{ step.date_day }}</div>
                        </div>
                        <div class="metadata-item">
                            <div class="metadata-label">
                                {% if step.night_weather_icon_url %}
                                    <img src="{{ step.night_weather_icon_url }}"
                                         alt="Night weather"
                                         class="weather-icon" />
                                {% endif %}
                                {{ step.temp_night_str }}
                            </div>
                            <div class="metadata-value">
                                {% if step.day_weather_icon_url %}
                                    <img src="{{ step.day_weather_icon_url }}"
                                         alt="Day weather"
                                         class="weather-icon" />
                                {% endif %}
                                {{ step.temp_str }}
                            </div>
                        </div>
                        <div class="metadata-item">
                            <div class="metadata-label">m.a.s.l</div>
                            <div class="metadata-value">{{ step.altitude_str }}</div>
                        </div>
                    </div>
                    <div class="progress-container">
                        <div class="progress-bar">
                            <div class="progress-fill"
                                 style="width: {{ step.progress_percent }}%;
                                        background: {{ step.accent_color }}"></div>
                        </div>
                        <div class="step-counter-arrow"
                             style="border-bottom-color: {{ step.accent_color }};
                                    left: {{ step.day_counter_arrow_position }}%;
                                    transform: translateX(-55%)"></div>
                        <div class="step-counter-wrapper"
                             style="left: {{ step.day_counter_box_position }}%;
                                    transform: translateX(-55%)">
                            <div class="step-counter" style="background: {{ step.accent_color }};">STEP {{ step.index + 1 }}</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="step-content">
                {% if step.is_long_description %}
                    <div class="step-description long" dir="{{ step.description | text_dir }}">{{- step.description -}}</div>
                {% else %}
                    <img src="{{ step.cover_photo.path }}"
                         alt="{{ step.name }}"
                         class="main-image cover-photo"
                         loading="lazy"
                         decoding="async"
                         data-photo-path="{{ step.cover_photo.path }}" />
                {% endif %}
            </div>
            <div class="step-index">{{ step.index + 1 }}</div>
        </div>
        {% if step.extra_description %}
            <div class="step-page page-container">
                <div class="step-description long"
                     dir="{{ step.extra_description | text_dir }}">{{- step.extra_description -}}</div>
                <div class="step-index">{{ step.index + 1 }}</div>
            </div>
        {% endif %}
        {% for photo_page in step.photo_pages %}
            <div class="step-page photo-page page-container">
                <div class="photo-page-container {{ photo_page.layout_class or '' }}"
                     {% if photo_page.grid_style %}style="{{ photo_page.grid_style }}"{% endif %}>
                    {% for photo in photo_page.photos %}
                        {% include "photo_item.html.jinja" %}
                    {% endfor %}
                </div>
            </div>
        {% endfor %}
        <div class="add-page-container">
            <button class="add-page-btn"
                    title="Add Photo Page"
                    onclick="addPhotoPage(this)">+</button>
        </div>
    </div>
    <div class="unused-photos-wrapper">
        <div class="unused-photos-header">Unused Photos</div>
        <div class="unused-photos-container">
            {% for photo in step.unused_photos %}
                {% include "photo_item.html.jinja" %}
            {% endfor %}
        </div>
    </div>
</div>
