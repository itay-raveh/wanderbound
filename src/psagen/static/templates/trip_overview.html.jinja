<div class="overview-container page-container">
    <div class="overview-sidebar">
        {% for country, flag_url in overview.countries %}
            <div class="country-item">
                <img src="{{ flag_url }}"
                     class="country-flag-icon"
                     alt="{{ country }} flag" />
                <div>{{ country }}</div>
            </div>
        {% endfor %}
    </div>
    <div class="overview-main">
        <img src="data:image/svg+xml;base64,"
             class="overview-bg"
             alt="Abstract hills" />
        <div class="overview-content">
            <div class="stats-grid">
                <div class="stat-item">
                    <img class="stat-icon"
                         src="data:image/svg+xml;base64,"
                         alt="Globe Icon" />
                    <div class="stat-number">{{ overview.total_km }}</div>
                    <div class="stat-unit">Kilometers</div>
                </div>
                <div class="stat-item">
                    <img class="stat-icon"
                         src="data:image/svg+xml;base64,"
                         alt="Calendar Icon" />
                    <div class="stat-number">{{ overview.total_days }}</div>
                    <div class="stat-unit">days</div>
                </div>
                <div class="stat-item">
                    <img class="stat-icon"
                         src="data:image/svg+xml;base64,"
                         alt="Location Pin Icon" />
                    <div class="stat-number">{{ overview.step_count }}</div>
                    <div class="stat-unit">steps</div>
                </div>
                <div class="stat-item">
                    <img class="stat-icon"
                         src="data:image/svg+xml;base64,"
                         alt="Camera Icon" />
                    <div class="stat-number">{{ overview.photo_count }}</div>
                    <div class="stat-unit">photos</div>
                </div>
            </div>
            <div class="stats-furthest-container">
                <div class="stats-furthest-item">
                    <div class="stats-furthest-circle">
                        <img class="stats-furthest-icon"
                             alt=""
                             src="data:image/svg+xml;base64,">
                    </div>
                    <div class="stats-furthest-name">{{ overview.furthest_point.home_name }}</div>
                </div>
                <div class="stats-furthest-center">
                    <div class="stats-furthest-point-bubble">
                        <div>
                            {{ overview.furthest_point.distance_km }} <span class="stats-furthest-point-superindex">KM</span>
                        </div>
                        <img class="stats-furthest-point-bubble-arrow"
                             alt=""
                             src="data:image/svg+xml;base64,">
                    </div>
                    <div class="stats-furthest-line-container">
                        <img src="data:image/svg+xml;base64,"
                             alt=""
                             class="stats-furthest-line">
                    </div>
                    <div class="stats-furthest-point-text">Furthest point from home</div>
                </div>
                <div class="stats-furthest-item">
                    <div class="stats-furthest-circle">
                        <img class="stats-furthest-icon"
                             alt=""
                             src="data:image/svg+xml;base64,">
                    </div>
                    <div class="stats-furthest-name">{{ overview.furthest_point.furthest_name }}</div>
                </div>
            </div>
        </div>
    </div>
</div>
