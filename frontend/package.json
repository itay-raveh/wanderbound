{
  "name": "frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "ensure:countries": "ls public/countries/*.svg >/dev/null 2>&1 || (cd .. && uv run scripts/generate_country_svgs.py)",
    "dev": "bun run ensure:countries; openapi-ts; vite",
    "build": "openapi-ts && vue-tsc -b tsconfig.app.json tsconfig.node.json && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --project=fast",
    "test:e2e:full": "playwright test --project=full",
    "test:e2e:headed": "playwright test --headed",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "screenshots": "bun scripts/landing-screenshots.ts"
  },
  "dependencies": {
    "@azure/msal-browser": "^5.6.1",
    "@chenglou/pretext": "^0.0.4",
    "@hey-api/client-fetch": "^0.13.1",
    "@mapbox/mapbox-gl-supported": "^3.0.0",
    "@pinia/colada": "^1.0.0",
    "@quasar/extras": "^1.17.0",
    "@sentry/vue": "^10.45.0",
    "@tanstack/vue-virtual": "^3.13.23",
    "@turf/along": "^7.3.4",
    "@turf/bezier-spline": "^7.3.4",
    "@turf/distance": "^7.3.4",
    "@turf/helpers": "^7.3.4",
    "@turf/length": "^7.3.4",
    "@turf/nearest-point-on-line": "^7.3.4",
    "canvas-confetti": "^1.9.4",
    "d3-scale": "^4.0.2",
    "mapbox-gl": "^3.20.0",
    "marked": "^17.0.5",
    "pinia": "^3.0.4",
    "postcss-rtlcss": "^5.7.1",
    "quasar": "^2.18.7",
    "vue": "^3.5.30",
    "vue-draggable-plus": "^0.6.1",
    "vue-i18n": "^11.3.0",
    "vue-router": "^4.6.4",
    "vue3-google-login": "^2.0.37"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.93.0",
    "@intlify/unplugin-vue-i18n": "^11.0.7",
    "@playwright/test": "^1.58.2",
    "@quasar/vite-plugin": "^1.11.0",
    "@sentry/vite-plugin": "^5.1.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/d3-scale": "^4.0.9",
    "@types/node": "^24.12.0",
    "@types/sharp": "^0.32.0",
    "@types/sortablejs": "^1.15.9",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "happy-dom": "^20.8.4",
    "msw": "^2.12.14",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "sharp": "^0.34.5",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.6"
  }
}
